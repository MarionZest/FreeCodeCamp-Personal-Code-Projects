<!--Styles.css code below!-->

body {
  background-color: rosybrown;
  font-family: Arial, sans-serif; 
}

.business-card {
  width: 300px;
  background-color: lightblue;
  padding: 20px;
  margin-top: 100px;
  margin-left: auto;
  margin-right: auto;
  font-size: 16px;
  text-align: center;
}

.profile-image {
  max-width: 100%;
}

p {
  margin-top: 5px;
  margin-bottom: 5px;
}

a {
  text-decoration: none;
  color: purple;
}

a:hover {
  text-decoration: underline;
  color: navy;
}
